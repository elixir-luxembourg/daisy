ENVIRONMENT=test
DEBUG=True
SECRET_KEY=ci-test-secret-not-for-production
GLOBAL_API_KEY=ci-test-api-key
TEST=True

DATABASE_URL=postgres://daisy:daisy@localhost:5432/daisy
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
SOLR_URL=http://localhost:8983/solr/daisy_test
SOLR_URL_TEST=http://localhost:8983/solr/daisy_test
SOLR_ADMIN_URL=http://localhost:8983/solr/admin/cores

STATIC_ROOT=/static
SASS_PROCESSOR_ROOT=/static

PASSWORD_HASHERS=django.contrib.auth.hashers.MD5PasswordHasher

HAYSTACK_SIGNAL_PROCESSOR=haystack.signals.RealtimeSignalProcessor

LDAP_ENABLED=True
AUTH_LDAP_SERVER_URI=ldap://localhost/
AUTH_LDAP_BIND_DN=test
AUTH_LDAP_BIND_PASSWORD=password
AUTH_LDAP_ALLOWED_USERS=normal.user@uni.lu,user@uni.lu
LDAP_USERS_IMPORT_CLASS=(objectClass=person)
LDAP_USERS_IMPORT_SEARCH_DN=OU=LCSB,OU=Faculties,OU=UNI-Users,DC=uni,DC=lux
AUTH_LDAP_FILTER_USERS=(&(userPrincipalName=%(user)s)(mail=*@uni.lu)(objectClass=person)(userPrincipalName={user_principal_name}))
AUTH_LDAP_ALLOWED_USERS_EXT=ext.user@uni.lu
AUTH_LDAP_FILTER_USERS_EXT=(&(userPrincipalName=%(user)s)(mail=*@ext.uni.lu)(objectClass=person)(userPrincipalName={user_principal_name}))
LDAP_BASE_DN_WITH_PRINCIPAL_USER=OU=UNI-Users,DC=uni,DC=lux

REMS_INTEGRATION_ENABLED=True
REMS_URL=http://localhost:3000/
REMS_API_KEY=test
REMS_API_USER=test
REMS_RETRIES=1
REMS_VERIFY_SSL=True
REMS_SKIP_IP_CHECK=False
REMS_ALLOWED_IP_ADDRESSES=127.0.0.1

KEYCLOAK_INTEGRATION=False
OIDC_ENABLED=False

ALLOWED_HOSTS=localhost,127.0.0.1,testserver,web
