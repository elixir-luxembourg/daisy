# GitHub Actions CI environment
# Matches old settings_compose_ci.py + settings_ci.py configuration

ENVIRONMENT=test
DEBUG=True
SECRET_KEY=ci-test-secret-not-for-production
GLOBAL_API_KEY=ci-test-api-key

# Database
DATABASE_URL=postgres://daisy:daisy@db:5432/daisy

# Celery
CELERY_BROKER_URL=amqp://guest:guest@mq:5672//

# Solr
SOLR_URL=http://solr:8983/solr/daisy_test
SOLR_URL_TEST=http://solr:8983/solr/daisy_test
SOLR_ADMIN_URL=http://solr:8983/solr/admin/cores

# Static files
STATIC_ROOT=/static
SASS_PROCESSOR_ROOT=/static

# CRITICAL: Fast password hashing for CI performance
PASSWORD_HASHERS=django.contrib.auth.hashers.MD5PasswordHasher

# Haystack - use RealtimeSignalProcessor (synchronous) for tests
HAYSTACK_SIGNAL_PROCESSOR=haystack.signals.RealtimeSignalProcessor

# Email backend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# LDAP Configuration (for LDAP tests with mockldap)
LDAP_ENABLED=True
AUTH_LDAP_SERVER_URI=ldap://localhost/
AUTH_LDAP_BIND_DN=CN=Normal.User,OU=LCSB,OU=Faculties,OU=UNI-Users,DC=uni,DC=lux
AUTH_LDAP_BIND_PASSWORD=password
AUTH_LDAP_USER_SEARCH_BASE=OU=Faculties,OU=UNI-Users,DC=uni,DC=lux
AUTH_LDAP_USER_SEARCH_FILTER=(userPrincipalName=%(user)s)
AUTH_LDAP_USER_ATTR_MAP_FIRST_NAME=givenName
AUTH_LDAP_USER_ATTR_MAP_LAST_NAME=sn
AUTH_LDAP_USER_ATTR_MAP_EMAIL=mail
LDAP_USERS_IMPORT_CLASS=(objectClass=person)
LDAP_USERS_IMPORT_USERNAME_ATTR=userprincipalname
AUTH_LDAP_USER_DN_TEMPLATE=CN=%(user)s,OU=LCSB,OU=Faculties,OU=UNI-Users,DC=uni,DC=lux
LDAP_USERS_IMPORT_SEARCH_DN=OU=LCSB,OU=Faculties,OU=UNI-Users,DC=uni,DC=lux

# REMS Configuration
REMS_INTEGRATION_ENABLED=True
REMS_URL=http://localhost:3000/
REMS_API_KEY=test
REMS_API_USER=test
REMS_RETRIES=1
REMS_VERIFY_SSL=True
REMS_SKIP_IP_CHECK=False
REMS_ALLOWED_IP_ADDRESSES=127.0.0.1

# Allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,testserver,web

# Logging
LOG_LEVEL=INFO
