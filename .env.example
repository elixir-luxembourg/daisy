# Template for environment variables
# Copy this file to .env.local, .env.compose, or .env.test and customize as needed
# Only set variables that differ from defaults in settings.py

# ============================================================================
# CORE SETTINGS
# ============================================================================

ENVIRONMENT=local  # Options: local, test, compose, production
DJANGO_READ_DOTENV=true

# Security (REQUIRED in production!)
SECRET_KEY=your-secret-key-here-change-in-production
GLOBAL_API_KEY=your-global-api-key-change-in-production

# Debug mode (defaults: local=True, others=False)
# DEBUG=True

# ============================================================================
# DATABASE
# ============================================================================

DATABASE_URL=postgres://user:password@host:5432/dbname
# Examples:
# Local: postgres://daisy:daisy@localhost:5432/daisy
# Docker: postgres://daisy:daisy@db:5432/daisy

# ============================================================================
# CELERY
# ============================================================================

CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
# CELERY_RESULT_BACKEND=django-db  # default
# CELERY_TIMEZONE=UTC  # defaults to TIME_ZONE

# ============================================================================
# SOLR
# ============================================================================

SOLR_URL=http://localhost:8983/solr/daisy
SOLR_URL_TEST=http://localhost:8983/solr/daisy_test
SOLR_ADMIN_URL=http://localhost:8983/solr/admin/cores

# For tests: use RealtimeSignalProcessor (synchronous)
# HAYSTACK_SIGNAL_PROCESSOR=haystack.signals.RealtimeSignalProcessor
# For production: use CelerySignalProcessor (async, default)
# HAYSTACK_SIGNAL_PROCESSOR=celery_haystack.signals.CelerySignalProcessor

# ============================================================================
# STATIC FILES
# ============================================================================

STATIC_ROOT=/static
SASS_PROCESSOR_ROOT=/static
# STATIC_URL=/static/  # default
# MEDIA_ROOT=/code/medias/  # default

# ============================================================================
# EMAIL
# ============================================================================

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=localhost  # default
# EMAIL_PORT=25  # default
# EMAIL_DONOTREPLY=do-not-reply@daisy.lcsb.uni.lu  # default
# HELPDESK_EMAIL=support@example.com  # default

# ============================================================================
# REMS
# ============================================================================

REMS_INTEGRATION_ENABLED=False
# REMS_URL=
# REMS_API_USER=
# REMS_API_KEY=
# REMS_VERIFY_SSL=True  # default
# REMS_RETRIES=3  # default
# REMS_SKIP_IP_CHECK=False  # default
# REMS_ALLOWED_IP_ADDRESSES=  # list, default empty

# ============================================================================
# LDAP AUTHENTICATION
# ============================================================================

LDAP_ENABLED=False
# When enabled, configure these:
# AUTH_LDAP_SERVER_URI=ldap://localhost/
# AUTH_LDAP_BIND_DN=CN=User,OU=Department,DC=domain,DC=com
# AUTH_LDAP_BIND_PASSWORD=password
# LDAP_USERS_IMPORT_CLASS=(objectClass=person)  # default
# LDAP_USERS_IMPORT_USERNAME_ATTR=userprincipalname  # default
# AUTH_LDAP_USER_DN_TEMPLATE=CN=%(user)s,OU=Department,DC=domain,DC=com
# LDAP_USERS_IMPORT_SEARCH_DN=OU=Department,DC=domain,DC=com
# PREDEFINED_PIS_LIST=name.surname@uni.lu,othername.othersurname@uni.lu

# ============================================================================
# OIDC/KEYCLOAK AUTHENTICATION
# ============================================================================

# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_METADATA_URL=

# Keycloak admin integration
# KEYCLOAK_URL=https://sso.lcsb.uni.lu/  # default
# KEYCLOAK_REALM_LOGIN=End-2-End-Testing  # default
# KEYCLOAK_REALM_ADMIN=End-2-End-Testing  # default
# KEYCLOAK_USER=
# KEYCLOAK_PASS=
# KEYCLOAK_INTEGRATION=False  # default

# ============================================================================
# SECURITY & NETWORKING
# ============================================================================

ALLOWED_HOSTS=localhost,127.0.0.1
# CSRF_TRUSTED_ORIGINS=  # list, needed for Docker/nginx
# SESSION_COOKIE_SECURE=False  # auto: True for non-local
# CSRF_COOKIE_SECURE=False  # auto: True for non-local
# INTERNAL_IPS=127.0.0.1  # default

# ============================================================================
# LOGGING
# ============================================================================

LOG_LEVEL=DEBUG
# LOG_DIR=./log  # default BASE_DIR/log
# LOGFILE_MAX_BYTES=16777216  # default 16MB

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# COMPANY=LCSB  # default
# DEMO_MODE=False  # default
# INSTANCE_LABEL=  # optional custom label
# INSTANCE_PRIMARY_COLOR=  # optional custom color
# AUTH_USER_MODEL=core.User  # default

# Data Stewardship Wizard integration
# DSW_ORIGIN=localhost  # default

# ID Service
# IDSERVICE_FUNCTION=web.views.utils.generate_elu_accession  # default
# IDSERVICE_ENDPOINT=https://10.240.16.199:8080/v1/api/id  # default

# Access expiration
# ACCESS_DEFAULT_EXPIRATION_DAYS=90  # default

# Admin password changes
# ENABLE_PASSWORD_CHANGE_IN_ADMIN=False  # default

# ============================================================================
# AUTHENTICATION BACKENDS
# ============================================================================

# AUTHENTICATION_BACKENDS=django.contrib.auth.backends.ModelBackend,guardian.backends.ObjectPermissionBackend  # default
# LOGIN_REDIRECT_URL=dashboard  # default
# LOGIN_URL=login  # default
