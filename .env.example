ENVIRONMENT=local  # Options: local, test, compose, production
DJANGO_READ_DOTENV=true
DEBUG=False

SECRET_KEY=your-secret-key-here-change-in-production
GLOBAL_API_KEY=your-global-api-key-change-in-production

# ============================================================================
# DB and AMQP
# ============================================================================

DATABASE_URL=postgres://daisy:daisy@db:5432/daisy
# Local: postgres://daisy:daisy@localhost:5432/daisy

CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=django-db

SOLR_URL=http://localhost:8983/solr/daisy
SOLR_URL_TEST=http://localhost:8983/solr/daisy_test
SOLR_ADMIN_URL=http://localhost:8983/solr/admin/cores

# For tests: use RealtimeSignalProcessor (synchronous)
# http://django-haystack.readthedocs.io/en/master/signal_processors.html?highlight=RealtimeSignalProcessor
# HAYSTACK_SIGNAL_PROCESSOR=haystack.signals.RealtimeSignalProcessor
# For production: use CelerySignalProcessor (async, default)
# HAYSTACK_SIGNAL_PROCESSOR=celery_haystack.signals.CelerySignalProcessor

# ============================================================================
# STATIC FILES
# ============================================================================

STATIC_ROOT=/static
SASS_PROCESSOR_ROOT=/static
# STATIC_URL=/static/  # default
# MEDIA_ROOT=/code/medias/  # default

# ============================================================================
# REMS
# ============================================================================

REMS_INTEGRATION_ENABLED=False
# REMS_URL=
# REMS_API_USER=
# REMS_API_KEY=
# REMS_VERIFY_SSL=True  # default
# REMS_RETRIES=3  # default
# REMS_SKIP_IP_CHECK=False  # default
# REMS_ALLOWED_IP_ADDRESSES=  # list, default empty

# ============================================================================
# AUTHENTICATION
# ============================================================================

LDAP_ENABLED=False
# AUTH_LDAP_SERVER_URI=ldap://localhost/
# AUTH_LDAP_BIND_DN=CN=User,OU=Department,DC=domain,DC=com
